NODE_ENV=development
PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
DATABASE_URL=postgresql://user:password@host:5432/platform_db?sslmode=require
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://*.pages.dev

# Cloudflare R2 (API 2 partition)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://pub-your-r2-domain.r2.dev

# Email (notification-core / Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=FBAppInc <no-reply@yourdomain.com>
EMAIL_SEND_ENABLED=true
# EMAIL_REPLY_TO=support@yourdomain.com
# EMAIL_LOG_LEVEL=info
APP_URL=https://fbapp.pages.dev

# Optional: throttling overrides (currently configured in code)
# THROTTLE_GLOBAL_LIMIT=120
# THROTTLE_GLOBAL_TTL_MS=60000